<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <connectionStrings>
    <add name="AssemblyDb" connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=AssemblyManager;Integrated Security=True;" />
    <add name="MasterDb" connectionString="Data Source=(localdb)\MSSQLLocalDB;Initial Catalog=master;Integrated Security=True;" />
  </connectionStrings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
  </startup>
</configuration>